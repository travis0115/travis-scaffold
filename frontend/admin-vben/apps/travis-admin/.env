# 应用标题
VITE_APP_TITLE=Travis Admin

# 应用命名空间，用于缓存、store等功能的前缀，确保隔离
VITE_APP_NAMESPACE=travis-admin-vben

# 对store进行加密的密钥，在将store持久化到localStorage时会使用该密钥进行加密
VITE_APP_STORE_SECURE_KEY=o8UIVpRaBGx4F3a74vEfTpnHo27bEn6n

# public path
VITE_BASE=/

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 单文件上传大小限制（字节），默认 20MB
#VITE_UPLOAD_FILE_MAX_SIZE=20971520
VITE_UPLOAD_FILE_MAX_SIZE=1

# 是否启用部门功能（true/false）
VITE_BIZ_DEPT_ENABLED=true
