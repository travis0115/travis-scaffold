<included>
    <!-- 标准输出，交由容器采集 -->
    <condition class="com.travis.infrastructure.framework.logging.core.logback.condition.TravisExpressionPropertyCondition">
        <expression>propertyEqualsIgnoreCase("LOG_OUTPUT","stdout")</expression>
    </condition>
    <if>
        <then>
            <!-- 标准输出，交由容器采集 -->
            <include resource="logback/appenders/appender-stdout-app.xml"/>
            <root level="INFO">
                <appender-ref ref="ASYNC_APPENDER_STDOUT_APP"/>
            </root>
            <condition
                    class="com.travis.infrastructure.framework.logging.core.logback.condition.TravisExpressionPropertyCondition">
                <expression>propertyEqualsIgnoreCase("LOG_ACCESS_ENABLED","true")</expression>
            </condition>
            <if>
                <then>
                    <!-- access -->
                    <include resource="logback/appenders/appender-stdout-access.xml"/>
                    <include resource="logback/logger/logger-stdout-access.xml"/>
                </then>
            </if>
        </then>
    </if>
    <!-- 文件输出 -->
    <condition class="com.travis.infrastructure.framework.logging.core.logback.condition.TravisExpressionPropertyCondition">
        <expression>propertyEqualsIgnoreCase("LOG_OUTPUT","file")</expression>
    </condition>
    <if>
        <then>
            <!-- 文件输出 -->
            <include resource="logback/appenders/appender-file-app.xml"/>
            <include resource="logback/appenders/appender-file-error.xml"/>
            <root level="INFO">
                <appender-ref ref="ASYNC_APPENDER_FILE_APP"/>
                <appender-ref ref="ASYNC_APPENDER_FILE_ERROR"/>
            </root>
            <condition
                    class="com.travis.infrastructure.framework.logging.core.logback.condition.TravisExpressionPropertyCondition">
                <expression>propertyEqualsIgnoreCase("LOG_ACCESS_ENABLED","true")</expression>
            </condition>
            <if>
                <then>
                    <!-- access -->
                    <include resource="logback/appenders/appender-file-access.xml"/>
                    <include resource="logback/logger/logger-file-access.xml"/>
                </then>
            </if>
        </then>
    </if>
</included>